{
  "version": 2,
  "name": "nexus-ai",
  "builds": [
    {
      "src": "api/package.json",
      "use": "@vercel/static-build",
      "config": {
        "installCommand": "npm install",
        "buildCommand": "echo 'No build needed for serverless functions'"
      }
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "installCommand": "npm install",
        "buildCommand": "npm run build",
        "outputDirectory": "dist/client"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/client/dist/nexus-ai/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    },
    "api/auth.ts": {
      "maxDuration": 30
    },
    "api/tasks.ts": {
      "maxDuration": 30
    },
    "api/ai.ts": {
      "maxDuration": 30
    }
  },
  "installCommand": "echo 'No root install needed'"
}
