{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "installCommand": "npm install",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/client/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    },
    "api/auth.ts": {
      "maxDuration": 30
    },
    "api/tasks.ts": {
      "maxDuration": 30
    },
    "api/ai.ts": {
      "maxDuration": 30
    }
  }
}
